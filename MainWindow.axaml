<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SyncraRPC.MainWindow"
        x:CompileBindings="False"
        Title="Syncra RPC Hub"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e"
        Foreground="White"
        SystemDecorations="None"
        CornerRadius="8">
    <Grid RowDefinitions="40, *">
        <Grid Grid.Row="0" ColumnDefinitions="250, *, Auto" Background="Transparent" PointerPressed="OnTitleBarPointerPressed">
            <Border Grid.Column="0" Background="#161616" BorderThickness="0">
                <TextBlock Text="Syncra RPC" FontSize="18" FontWeight="Bold" Margin="20,0,20,0" VerticalAlignment="Center" Foreground="#416188"/>
            </Border>
            
            <Border Grid.Column="1" Background="#1e1e1e" BorderThickness="0" />
            <Border Grid.Column="2" Background="#1e1e1e" BorderThickness="0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="—" 
                            Width="45" Height="40" 
                            Background="Transparent" 
                            BorderThickness="0"
                            CornerRadius="0" 
                            Foreground="#aaaaaa"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                            Click="OnMinimizeClick">
                    </Button>
                    
                    <Button Content=">" 
                            Width="45" Height="40" 
                            Background="Transparent" 
                            BorderThickness="0"
                            CornerRadius="0" 
                            Foreground="#aaaaaa"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                            Click="OnCloseUI">
                    </Button>

                    <Button Content="✕" 
                            Width="45" Height="40" 
                            Background="Transparent" 
                            BorderThickness="0"
                            CornerRadius="0" 
                            Foreground="#aaaaaa"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                            Click="OnCloseClick">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#e81123"/>
                                <Setter Property="TextBlock.Foreground" Value="White"/>
                                <Setter Property="CornerRadius" Value="0"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="250, *">
            <Border Grid.Column="0" Background="#161616" BorderThickness="0">
                <Grid RowDefinitions="Auto, *">
                    <ListBox Grid.Row="1" Name="MenuListBox" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" SelectionChanged="OnMenuSelectionChanged">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="15,12"/>
                                <Setter Property="Margin" Value="10,2"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#2d2d2d"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="#5865F2"/>
                                <Setter Property="TextBlock.Foreground" Value="White"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBoxItem Name="MainTabItem" IsSelected="True">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Главная" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        
                        <ListBoxItem Name="SettingsTabItem">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Настройки" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto, *">
                <Carousel Grid.Row="1" Name="ContentCarousel" Margin="30,10,30,30">
                    <StackPanel Spacing="20" VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
                        <TextBlock Text="Управление статусом Discord" FontSize="16" HorizontalAlignment="Center" Foreground="#aaaaaa"/>
                        <Button Name="RpcActivationButton" 
                                Content="Включить SyncraRPC"
                                Height="45"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="#5865F2"
                                Foreground="White"
                                CornerRadius="6"
                                Click="onActivateSyncraRPC"/>
                    </StackPanel>

                    <!-- настройки -->
                    <StackPanel Spacing="15" VerticalAlignment="Top">
                        <TextBlock Text="Настройки" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <!-- 1 переключатель -->
                        <StackPanel MaxWidth="400" Spacing="2">
                            <Grid>
                                <TextBlock Text="Чтото оно точно делает" 
                                        FontSize="16"
                                        Foreground="#ffffff"
                                        FontWeight="Bold"
                                        VerticalAlignment="Center"
                                        Margin="0,0,50,0"/>
                                        
                                <CheckBox IsChecked="{Binding ShowTimestamp}" 
                                        Classes="switch"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Это просто тестовый текст не обращай внимание и все будет хорошо, а тут тест на длинну, тест прошел отлично ну все тогда"
                                    Foreground="#aaaaaa"
                                    FontSize="12"
                                    TextWrapping="Wrap"/>
                                    
                        </StackPanel>

                        <!-- Выбор из множества -->

                        <StackPanel MaxWidth="400" Spacing="2" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Вывод Дополнительной Информации" 
                                            FontSize="16"
                                            Foreground="#ffffff"
                                            FontWeight="Bold"
                                            VerticalAlignment="Center"
                                            Margin="0,0,50,0"/>
                                <TextBlock Text="Отправляет все (или выбранные вами) сообщения о работе программы. Например: ошибки соединения, новые запущенные программы"
                                        Foreground="#aaaaaa" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/> 
                            </StackPanel>

                            <StackPanel>
                                <RadioButton GroupName="Вывод Дополнительной Информации" IsChecked="True"  Margin="0,9,0,0">
                                    <StackPanel Orientation="Vertical" Spacing="2" MaxWidth="350">
                                        <TextBlock Text="Отправлять всё" 
                                                FontSize="14" 
                                                Foreground="#ffffff" 
                                                FontWeight="SemiBold"/>
                                                
                                        <TextBlock Text="Отправляет всю информацию в отдельный раздел 'Консоль' найти раздел можно слева"
                                                FontSize="11" Foreground="#aaaaaa" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton GroupName="Вывод Дополнительной Информации" Margin="0,7,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Только Критические Ошибки"
                                            FontSize="14" Foreground="#ffffff" FontWeight="SemiBold"/>
                                        
                                        <TextBlock
                                            Text="Показывает всплывающее сообщение с описанием критической ошибкой сверху справа. При нажатии можно увидеть больше информации о ошибки"
                                            FontSize="11" Foreground="#aaaaaa" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton GroupName="Вывод Дополнительной Информации" IsEnabled="False" Margin="0,7,0,0">
                                    <StackPanel >
                                        <TextBlock Text="Кастомная настройка"
                                            FontSize="14" Foreground="#707070" FontWeight="SemiBold"/>
                                        
                                        <TextBlock Text="Покачто не доступно."
                                            FontSize="11" Foreground="#707070" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>

                </Carousel>
            </Grid>
        </Grid>

        <Panel Name="WarningOverlay" 
                Grid.Row="1" 
                ZIndex="1000" 
                IsVisible="False"
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch">

                <Border Background="#80000000" /> 

                <Border Width="300" 
                        Height="150" 
                        Background="#2B2D31" 
                        CornerRadius="8" 
                        BorderBrush="#5865F2" 
                        BorderThickness="1"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                    
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                        
                        <!-- Текст предупреждения -->
                        <TextBlock Text="Осторожно!" 
                                FontSize="16" 
                                FontWeight="Bold" 
                                Foreground="White" 
                                HorizontalAlignment="Center"/>
                                
                        <TextBlock Text="При нажатии на данную кнопку закроется только UI программы. Вернуть UI обратно можно нажать на иконку приложения в трее" 
                                Foreground="#aaaaaa" 
                                HorizontalAlignment="Center" 
                                TextWrapping="Wrap"/>

                        <Button Click="BtnAcceptHidingTrayOk"
                                Content="Хорошо!" 
                                Width="100" 
                                Height="32" 
                                Background="#5865F2" 
                                Foreground="White" 
                                HorizontalAlignment="Center"/>
                                
                    </StackPanel>
                </Border>
            </Panel>
    </Grid>
</Window>